{
	"name": "ravit-dabush",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "concurrently \"next dev --turbo\" \"npm run open:browser\"",
		"build": "next build",
		"start": "next start",
		"lint": "eslint src && tsc && prettier src --check",
		"check:updates": "node check-updates.mjs",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,scss,css,json,md,html}\"",
		"open:browser": "node -e \"import('open').then(open => open.default('http://localhost:3000'))\""
	},
	"dependencies": {
		"@phosphor-icons/react": "^2.1.10",
		"clsx": "^2.1.1",
		"framer-motion": "^12.38.0",
		"highlight.js": "^11.11.1",
		"next": "^16.2.2",
		"next-intl": "^4.9.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sass": "^1.99.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.2.1",
		"eslint": "^10.2.0",
		"eslint-config-next": "^16.2.2",
		"open": "^11.0.0",
		"prettier": "3.8.1",
		"typescript": "^6.0.2",
		"wait-on": "^9.0.4"
	},
	"i18n ally": {
		"localesPaths": [
			"messages"
		],
		"pathMatcher": "{locale}/{namespace}.json",
		"enabledFrameworks": [
			"next-intl"
		],
		"sortKeys": false,
		"defaultLocale": "he"
	}
}
