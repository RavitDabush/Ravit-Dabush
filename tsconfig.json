{
	"compilerOptions": {
		"allowArbitraryExtensions": true,
		"target": "es2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"strict": true,
		"allowJs": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			},
			{
				"name": "next-intl"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"@messages/*": ["./messages/*"],
			"@public/*": ["./public"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"vitest.config.mts"
	],
	"exclude": ["node_modules"]
}
